{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./packages/shared/src/*"]
    }
  },
  "include": ["src", "packages/shared/src"],
  "exclude": ["packages/shared/src/**/__tests__/**"]
}
