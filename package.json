{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "main": "src/App.tsx",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "start": "expo start --reset-cache --dev-client",
    "android": "expo run:android",
    "ios": "SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "prebuild": "expo prebuild",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prebuild:check": "bash scripts/check-env.sh",
    "build:android": "npm run prebuild:check && eas build --profile development:device --platform android",
    "build:ios": "npm run prebuild:check && eas build --profile development:device --platform ios",
    "build:android:preview": "npm run prebuild:check && eas build --profile preview --platform android",
    "build:ios:preview": "npm run prebuild:check && eas build --profile preview --platform ios",
    "build:android:prod": "npm run prebuild:check && eas build --profile production --platform android",
    "build:ios:prod": "npm run prebuild:check && eas build --profile production --platform ios",
    "update:staging": "eas update --branch staging --message",
    "update:production": "eas update --branch production --message"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.90.0",
    "@tanstack/query-sync-storage-persister": "^5.90.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.0",
    "axios": "^1.9.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "i18next": "^26.0.3",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^2.12.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "react-native-svg": "^15.12.1",
    "react-native-toast-message": "^2.3.0",
    "react-native-webview": "13.15.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    },
    "testEnvironment": "node",
    "preset": "jest-expo/ios",
    "setupFiles": [
      "react-native/jest/setup",
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|expo/virtual/.*|@sentry/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|react-native-mmkv|react-native-reanimated|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|react-native-toast-message|react-native-svg|react-native-webview|react-native-ssl-public-key-pinning|@tanstack/.*|zustand|i18next|react-i18next|zod|lucide-react-native)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@shared/(.*)$": "<rootDir>/packages/shared/src/$1",
      "^expo/virtual/env$": "<rootDir>/src/__mocks__/expo-env.ts"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  }
}